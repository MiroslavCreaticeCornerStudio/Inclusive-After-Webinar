---
import { withBase } from "../lib/withBase";

const cards = [
  {
    icon: "/assets/images/icon-1.svg",
    title: "Подкрепа от експерти с 10+ години опит",
    text: "Работиш с хора, които знаят играта до съвършенство и споделят опита си с теб.",
  },
  {
    icon: "/assets/images/icon-2.svg",
    title: "Достъп до съвременна обучителна платформа",
    text: "Без суха теория, само реални казуси и ситуации от пазара.",
  },
  {
    icon: "/assets/images/icon-3.svg",
    title: "Специализирани тренинги",
    text: "Редовни обучения с доказани български и международни лектори в продажбите.",
  },
  {
    icon: "/assets/images/icon-4.svg",
    title: "Реално кариерно развитие",
    text: "Възможност да изградиш име на пазара и бързо да застанеш начело на свой екип.",
  },
  {
    icon: "/assets/images/icon-5.svg",
    title: "Доходи, обвързани с твоя успех",
    text: "Печелиш правопропорционално на твоите резултати и сделки. Без никакви тавани.",
  },
  {
    icon: "/assets/images/icon-6.svg",
    title: "Свобода за растеж без изкуствени лимити",
    text: "Развиваш се със собствено темпо, но с усещането, че никога не си сам на терен.",
  },
  {
    icon: "/assets/images/icon-7.svg",
    title: "Интензивни ролеви игри и тренировки",
    text: "Симулации на срещи и преговори, които вдигат увереността ти двойно.",
  },
];
---

<section class="expect" id="kakvo-te-ochakva">
  <div class="expect__inner container">
    <header class="expect__header">
      <h2 class="expect__title">Какво те очаква в inclusive?</h2>
      <a class="btn expect__cta" href="#kandidatstvay">Стани част от екипа</a>
    </header>
  </div>

  <div class="expect__content container">
    <div class="expect__scroll" tabindex="0" aria-label="Какво те очаква — превърти хоризонтално">
      <ul class="expect__track">
        {cards.map((card) => (
          <li class="expect__card">
            <div class="expect__card-top">
              <img class="expect__icon" src={withBase(card.icon)} alt="" width="40" height="40" aria-hidden="true" />
              <h3 class="expect__card-title">{card.title}</h3>
            </div>
            <span class="gold-rule"></span>
            <p class="expect__card-text">{card.text}</p>
          </li>
        ))}
      </ul>
    </div>

    <div class="expect__progress" aria-hidden="true">
      <span class="expect__progress-bar"></span>
    </div>

    <div class="expect__nav">
      <button class="expect__arrow" type="button" data-dir="prev" aria-label="Предишна карта">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7" /></svg>
      </button>
      <button class="expect__arrow" type="button" data-dir="next" aria-label="Следваща карта">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .expect {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-block: 5em; /* 80px */
    display: flex;
    flex-direction: column;
    gap: 4em; /* 64px */
  }

  .expect__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2em;
    width: 100%;
  }

  .expect__title {
    max-width: 36.125em; /* 578px */
    font-family: var(--font-heading);
    font-size: 3em; /* 48px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-20);
  }

  .expect__cta {
    flex-shrink: 0;
  }

  .expect__content {
    display: flex;
    flex-direction: column;
    gap: 3.5em; /* 56px */
  }

  .expect__scroll {
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
    cursor: grab;
  }

  .expect__scroll::-webkit-scrollbar {
    display: none;
  }

  .expect__scroll.is-dragging {
    cursor: grabbing;
    user-select: none;
    scroll-snap-type: none;
  }

  .expect__track {
    display: flex;
    width: max-content;
  }

  .expect__card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1em; /* 16px */
    width: 26em; /* 416px */
    padding: 2.5em 2.375em; /* 40px 38px */
    border: 1px solid var(--color-gray-60);
    border-left: none;
  }

  .expect__card:first-child {
    border-left: 1px solid var(--color-gray-60);
  }

  .expect__card-top {
    display: flex;
    flex-direction: column;
    gap: 1.625em; /* 26px */
    width: 100%;
  }

  .expect__icon {
    width: 2.5em; /* 40px */
    height: 2.5em;
  }

  .expect__card-title {
    font-family: var(--font-heading);
    font-size: 2em; /* 32px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-10);
  }

  .expect__card-text {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.4;
    color: var(--color-gray-20);
  }

  /* Scroll progress indicator */
  .expect__progress {
    align-self: flex-end;
    width: 13.75em; /* 220px */
    height: 8px;
    background-color: var(--color-gray-80);
    overflow: hidden;
  }

  .expect__progress-bar {
    display: block;
    width: 38%;
    height: 100%;
    background-color: var(--color-gold);
  }

  /* Slider nav arrows */
  .expect__nav {
    display: flex;
    gap: 1em;
    justify-content: flex-end;
  }

  .expect__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.6875em; /* 43px */
    height: 2.6875em;
    background: var(--color-gold);
    color: var(--color-gray-100);
    border: none;
    cursor: pointer;
  }

  @media (max-width: 767px) {
    .expect__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5em;
    }

    .expect__title {
      font-size: 1.875em; /* ~30px */
    }

    .expect__cta {
      width: 100%;
    }

    /* Mobile: stacked cards instead of a slider */
    .expect__scroll {
      overflow: visible;
      cursor: default;
    }

    .expect__track {
      flex-direction: column;
      width: 100%;
      gap: 1em;
    }

    .expect__card {
      width: 100%;
      border: 1px solid var(--color-gray-60);
      padding: 1.5em; /* 24px */
    }

    .expect__card-title {
      font-size: 1.5em; /* ~24px */
    }

    .expect__card-text {
      font-size: 1.125em; /* ~18px */
    }

    /* No slider controls when the cards are stacked */
    .expect__progress,
    .expect__nav {
      display: none;
    }
  }
</style>

<script>
  const scroller = document.querySelector(".expect__scroll") as HTMLElement | null;
  const bar = document.querySelector(".expect__progress-bar") as HTMLElement | null;
  const arrows = document.querySelectorAll<HTMLButtonElement>(".expect__arrow");

  if (scroller) {
    const update = () => {
      if (!bar) return;
      const max = scroller.scrollWidth - scroller.clientWidth;
      const ratio = max > 0 ? scroller.scrollLeft / max : 0;
      const travel = 100 - 38; // bar is 38% wide
      bar.style.marginLeft = `${ratio * travel}%`;
    };
    scroller.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();

    // Prev/next arrows scroll by one card width (+ gap).
    const step = () => {
      const card = scroller.querySelector(".expect__card") as HTMLElement | null;
      const track = scroller.querySelector(".expect__track") as HTMLElement | null;
      const gap = track ? parseFloat(getComputedStyle(track).columnGap) || 0 : 0;
      return card ? card.offsetWidth + gap : scroller.clientWidth;
    };
    arrows.forEach((btn) =>
      btn.addEventListener("click", () => {
        const dir = btn.dataset.dir === "prev" ? -1 : 1;
        scroller.scrollBy({ left: dir * step(), behavior: "smooth" });
      }),
    );

    // Click-and-drag to scroll (mouse only — touch keeps native swipe).
    let down = false;
    let startX = 0;
    let startScroll = 0;
    scroller.addEventListener("pointerdown", (e) => {
      if (e.pointerType !== "mouse") return;
      down = true;
      startX = e.clientX;
      startScroll = scroller.scrollLeft;
      scroller.classList.add("is-dragging");
      try {
        scroller.setPointerCapture(e.pointerId);
      } catch {}
    });
    scroller.addEventListener("pointermove", (e) => {
      if (!down) return;
      scroller.scrollLeft = startScroll - (e.clientX - startX);
    });
    const endDrag = (e: PointerEvent) => {
      if (!down) return;
      down = false;
      scroller.classList.remove("is-dragging");
      try {
        scroller.releasePointerCapture(e.pointerId);
      } catch {}
    };
    scroller.addEventListener("pointerup", endDrag);
    scroller.addEventListener("pointercancel", endDrag);
  }
</script>
