---
const testimonials = [
  {
    avatar: "/assets/images/avatar-1.jpg",
    name: "Вероника Баракова",
    role: "Мениджър, INclusive",
    quote:
      "„В INclusive всеки от нас има възможност да развива силните си страни и да подобрява слабите. Имаме подкрепа, надграждаме знанията си и ставаме все по-добри! Тук всеки един човек е важен с неговите индивидуални качества.“",
  },
  {
    avatar: "/assets/images/avatar-2.jpg",
    name: "Станислав Мишуров",
    role: "Мениджър, INclusive",
    quote:
      "„В INclusive сме като едно голямо семейство. Празнуваме победите заедно и се подкрепяме в трудните моменти. Имаме среда, в която новите хора могат да влязат бързо в ритъм, а по-опитните винаги са готови да помогнат.“",
  },
  {
    avatar: "/assets/images/avatar-3.jpg",
    name: "Николай Иванов",
    role: "Брокер, INclusive",
    quote:
      "„INclusive е една от най-разпознаваемите компании за недвижими имоти, с доказана система на работа. Като млад човек мога бързо да усвоя този модел и знам, че когато го следвам, резултатите идват. Средата е конкурентна, но точно това ме мотивира да се развивам.“",
  },
];
---

<section class="testimonials" id="ekip">
  <div class="testimonials__inner container">
    <header class="testimonials__header">
      <h2 class="testimonials__title">Нашите брокери споделят...</h2>
    </header>

    <ul class="testimonials__grid">
      {testimonials.map((t) => (
        <li class="testimonial">
          <div class="testimonial__person">
            <img class="testimonial__avatar" src={t.avatar} alt={t.name} width="80" height="80" loading="lazy" />
            <div class="testimonial__meta">
              <p class="testimonial__name">{t.name}</p>
              <p class="testimonial__role">{t.role}</p>
            </div>
          </div>
          <blockquote class="testimonial__quote">{t.quote}</blockquote>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .testimonials {
    width: 100%;
    background-color: var(--color-bg-dark);
    padding-bottom: 5em; /* 80px */
  }

  .testimonials__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5em; /* 56px */
  }

  .testimonials__title {
    max-width: 38.625em; /* 618px */
    font-family: var(--font-heading);
    font-size: 3em; /* 48px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-gray-10);
  }

  .testimonials__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.0625em; /* ~33px between, matches 372px cards in 1248 */
    width: 100%;
  }

  .testimonial {
    display: flex;
    flex-direction: column;
    gap: 2em; /* 32px */
    padding: 1.5em; /* 24px */
    border: 1px solid var(--color-gold);
    background-color: var(--color-bg-dark);
  }

  .testimonial__person {
    display: flex;
    align-items: flex-end;
    gap: 1em; /* 16px */
  }

  .testimonial__avatar {
    width: 5em; /* 80px */
    height: 5em;
    object-fit: cover;
    flex-shrink: 0;
  }

  .testimonial__meta {
    display: flex;
    flex-direction: column;
    gap: 0.5em; /* 8px */
  }

  .testimonial__name {
    font-family: var(--font-heading);
    font-size: 1.5em; /* 24px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-20);
  }

  .testimonial__role {
    font-family: var(--font-body);
    font-size: 1.125em; /* 18px */
    font-weight: 400;
    line-height: 1.2;
    color: var(--color-gray-20);
  }

  .testimonial__quote {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.4;
    color: var(--color-gray-20);
  }

  @media (max-width: 991px) {
    .testimonials__grid {
      grid-template-columns: 1fr;
      max-width: 32em;
      margin-inline: auto;
    }
  }
</style>
