---
const items = [
  {
    title: "Директна комуникация",
    text: "Разговори с купувачи, продавачи и партньори на пазара.",
    active: true,
  },
  { title: "Работа на терен" },
  { title: "Професионална подготовка" },
  { title: "Следене на пазара" },
  { title: "Реални преговори" },
  { title: "Екипна култура" },
];
---

<section class="everyday" id="rabota-pri-nas">
  <div class="everyday__inner container">
    <div class="everyday__head">
      <h2 class="everyday__title">Как ще изглежда ежедневието ти в INclusive?</h2>
    </div>

    <div class="everyday__media">
      <img src="/assets/images/everyday.jpg" alt="Брокер на INclusive в ежедневието си" width="608" height="683" loading="lazy" />
    </div>

    <ul class="everyday__list">
      {items.map((item) => (
        <li class={`everyday__item${item.active ? " is-active" : ""}`}>
          <h3 class="everyday__item-title">{item.title}</h3>
          {item.text && <p class="everyday__item-text">{item.text}</p>}
          {item.active && <span class="everyday__item-rule"></span>}
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .everyday {
    width: 100%;
    background-color: var(--color-gray-40);
    padding-block: 5em; /* 80px */
  }

  .everyday__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 38em; /* text | image 608px */
    grid-template-rows: auto 1fr;
    column-gap: 4em;
    align-items: stretch;
  }

  .everyday__head {
    grid-column: 1;
    grid-row: 1;
    display: flex;
    align-items: center;
    min-height: 11em; /* 176px */
  }

  .everyday__list {
    grid-column: 1;
    grid-row: 2;
    padding-top: 1.625em;
  }

  .everyday__title {
    font-family: var(--font-heading);
    font-size: 3em; /* 48px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-100);
  }

  .everyday__list {
    display: flex;
    flex-direction: column;
  }

  .everyday__item {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
    padding-bottom: 1.5em; /* 24px */
    border-bottom: 1px solid #c4c5c7;
  }

  .everyday__item + .everyday__item {
    padding-top: 1.5em;
  }

  .everyday__item-title {
    font-family: var(--font-heading);
    font-size: 1.5em; /* 24px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-100);
  }

  .everyday__item-text {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 400;
    line-height: 1.4;
    color: var(--color-gray-80);
  }

  .everyday__item-rule {
    display: block;
    width: 11.6875em; /* 187px */
    height: 3px;
    background: var(--color-gold);
  }

  .everyday__media {
    grid-column: 2;
    grid-row: 1 / span 2;
    border-radius: 0.25em;
    overflow: hidden;
  }

  .everyday__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Mobile design order: heading → image → list */
  @media (max-width: 991px) {
    .everyday__inner {
      display: flex;
      flex-direction: column;
      gap: 1.5em;
    }

    .everyday__head {
      order: 1;
      min-height: 0;
    }

    .everyday__media {
      order: 2;
    }

    .everyday__media img {
      height: auto;
    }

    .everyday__list {
      order: 3;
      padding-top: 0;
    }

    .everyday__title {
      font-size: 2.25em; /* 36px */
    }
  }

  @media (max-width: 767px) {
    .everyday__title {
      font-size: 1.875em; /* ~30px */
    }
  }
</style>
