---
import { withBase } from "../lib/withBase";

const beliefs = [
  "Най-силните резултати идват, когато има доверие в екипа",
  "Човек расте най-много в правилната среда",
  "Отношението към хората тежи повече от титлите",
  "Професионализмът личи в начина на работа, не в шумните думи",
  "Успехът е общ процес, а не индивидуално състезание",
];
---

<section class="cta" id="kandidatstvay" style={`--cta-bg: url("${withBase("/assets/images/cta-bg.jpg")}")`}>
  <div class="cta__panel container">
    <div class="cta__text">
      <div class="cta__heading">
        <h2 class="cta__title">Стани част от печелившия отбор!</h2>
        <span class="gold-rule"></span>
      </div>
      <div class="cta__beliefs">
        <p class="cta__beliefs-lead">Ако и ти вярваш, че:</p>
        <ul class="cta__list">
          {beliefs.map((b) => (
            <li class="cta__list-item">
              <span class="cta__dot"></span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <form class="cta__form" method="post" action={withBase("/api/apply")} novalidate>
      <div class="cta__field">
        <label class="cta__label" for="cta-name">Имена:</label>
        <input class="cta__input" id="cta-name" name="name" type="text" placeholder="Име Фамилия" autocomplete="name" required aria-describedby="cta-name-error" />
        <span class="cta__error" id="cta-name-error" aria-live="polite"></span>
      </div>
      <div class="cta__field">
        <label class="cta__label" for="cta-phone">Телефон:</label>
        <input class="cta__input" id="cta-phone" name="phone" type="tel" placeholder="Телефон" autocomplete="tel" required aria-describedby="cta-phone-error" />
        <span class="cta__error" id="cta-phone-error" aria-live="polite"></span>
      </div>
      <div class="cta__field">
        <label class="cta__label" for="cta-email">Имейл</label>
        <input class="cta__input" id="cta-email" name="email" type="email" placeholder="Имейл адрес" autocomplete="email" required aria-describedby="cta-email-error" />
        <span class="cta__error" id="cta-email-error" aria-live="polite"></span>
      </div>

      <div class="cta__field cta__file">
        <span class="cta__label">Прикачи CV <span class="cta__optional">(по желание)</span></span>
        <label class="cta__file-btn">
          <span class="cta__file-text">Избери файл (PDF, DOC, DOCX)</span>
          <input id="cta-cv" name="cv" type="file" accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document" aria-label="Прикачи CV файл" />
        </label>
        <div class="cta__file-progress" hidden><span class="cta__file-progress-fill"></span></div>
        <p class="cta__file-status" aria-live="polite" hidden></p>
      </div>

      <div class="cta__consent-field">
        <label class="cta__consent">
          <input class="cta__checkbox" type="checkbox" name="consent" required aria-describedby="cta-consent-error" />
          <span>Давам съгласието си данните ми да бъдат обработени съгласно приложения формуляр</span>
        </label>
        <span class="cta__error" id="cta-consent-error" aria-live="polite"></span>
      </div>

      <button class="btn cta__submit" type="submit">Кандидатствай сега!</button>
      <p class="cta__status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .cta {
    position: relative;
    width: 100%;
    padding-block: 5.25em; /* 84px */
    background-image: linear-gradient(rgba(33, 35, 43, 0.9), rgba(33, 35, 43, 0.9)),
      var(--cta-bg);
    background-size: cover;
    background-position: center;
  }

  .cta__panel {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    gap: 4.6875em; /* 75px */
    padding: 3em; /* 48px */
    border: 1px solid var(--color-gold);
  }

  .cta__text {
    display: flex;
    flex-direction: column;
    gap: 2.5em;
    flex: 1 1 36.5em; /* 584px */
    max-width: 36.5em;
  }

  .cta__heading {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
  }

  .cta__title {
    font-family: var(--font-heading);
    font-size: 3em; /* 48px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-10);
  }

  .cta__beliefs {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
  }

  .cta__beliefs-lead {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 400;
    color: var(--color-gray-40);
  }

  .cta__list {
    display: flex;
    flex-direction: column;
    gap: 0.5em; /* 8px */
  }

  .cta__list-item {
    display: flex;
    align-items: center;
    gap: 1em; /* 16px */
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    color: var(--color-gray-40);
  }

  .cta__dot {
    flex-shrink: 0;
    width: 0.5em; /* 8px */
    height: 0.5em;
    border-radius: 50%;
    background: var(--color-gold);
  }

  /* Form */
  .cta__form {
    display: flex;
    flex-direction: column;
    gap: 1.5em; /* 24px */
    flex: 0 0 24em; /* ~383px */
    max-width: 24em;
  }

  .cta__field {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .cta__label {
    font-family: var(--font-body);
    font-size: 1em; /* 16px */
    font-weight: 300;
    color: var(--color-gray-10);
  }

  .cta__input {
    width: 100%;
    height: 3em; /* 48px */
    padding-inline: 1em; /* 16px */
    background-color: var(--color-gray-80);
    border: 1px solid var(--color-gray-10);
    color: var(--color-gray-10);
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 300;
  }

  .cta__input::placeholder {
    color: var(--color-gray-10);
    opacity: 0.7;
  }

  .cta__input[aria-invalid="true"] {
    border-color: #ff8a8a;
  }

  .cta__consent-field {
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .cta__error {
    display: none;
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 400;
    line-height: 1.3;
    color: #ff8a8a;
  }

  .cta__error:not(:empty) {
    display: block;
  }

  .cta__consent {
    display: flex;
    align-items: flex-start;
    gap: 0.75em;
    font-family: var(--font-body);
    font-size: 1em; /* 16px */
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-gray-10);
    cursor: pointer;
  }

  .cta__checkbox {
    flex-shrink: 0;
    width: 0.875em; /* 14px */
    height: 0.875em;
    margin-top: 0.25em;
    accent-color: var(--color-gold);
  }

  .cta__submit {
    width: 100%;
    margin-top: 1em;
  }

  .cta__submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  .cta__status {
    font-family: var(--font-body);
    font-size: 1em;
    font-weight: 400;
    line-height: 1.4;
    min-height: 1.4em;
  }

  .cta__status:empty {
    display: none;
  }

  .cta__status[data-state="ok"] {
    color: var(--color-gold);
  }

  .cta__status[data-state="error"] {
    color: #ff8a8a;
  }

  /* CV upload */
  .cta__optional {
    font-weight: 300;
    color: var(--color-gray-40);
    opacity: 0.85;
  }

  .cta__file-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    align-self: flex-start;
    max-width: 100%;
    padding: 0.625em 1em; /* 10px 16px */
    border: 1px solid var(--color-gold);
    color: var(--color-gold);
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 400;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .cta__file-btn:hover {
    background-color: var(--color-gold);
    color: var(--color-gray-100);
  }

  .cta__file-btn input[type="file"] {
    display: none;
  }

  .cta__file-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 18em;
  }

  .cta__file-progress {
    width: 100%;
    height: 0.375em; /* 6px */
    margin-top: 0.125em;
    background-color: var(--color-gray-80);
    overflow: hidden;
  }

  .cta__file-progress[hidden] {
    display: none;
  }

  .cta__file-progress-fill {
    display: block;
    width: 0%;
    height: 100%;
    background-color: var(--color-gold);
    transition: width 0.2s ease;
  }

  .cta__file-status {
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 400;
    line-height: 1.3;
  }

  .cta__file-status[hidden] {
    display: none;
  }

  .cta__file-status[data-state="ok"] {
    color: var(--color-gold);
  }

  .cta__file-status[data-state="error"] {
    color: #ff8a8a;
  }

  @media (max-width: 991px) {
    .cta__panel {
      flex-direction: column;
      gap: 2.5em;
    }

    .cta__text,
    .cta__form {
      flex: 1 1 100%;
      max-width: none;
    }
  }

  @media (max-width: 767px) {
    .cta__title {
      font-size: 2.75em; /* 44px */
    }
  }
</style>

<script>
  import { upload } from "@vercel/blob/client";
  import { withBase } from "../lib/withBase";

  const form = document.querySelector(".cta__form") as HTMLFormElement | null;
  const status = document.querySelector(".cta__status") as HTMLElement | null;
  const submit = form?.querySelector(".cta__submit") as HTMLButtonElement | null;

  if (form) {
    const fields = ["name", "phone", "email", "consent"] as const;
    type FieldName = (typeof fields)[number];

    const messages: Record<FieldName, string> = {
      name: "Моля, въведи името и фамилията си.",
      phone: "Моля, въведи валиден телефонен номер.",
      email: "Моля, въведи валиден имейл адрес.",
      consent: "Необходимо е съгласие, за да продължиш.",
    };

    const emailRe = /^[^@\s]+@[^@\s]+\.[^@\s]+$/;
    const phoneRe = /^[+\d][\d\s\-()]*$/;

    const field = (name: FieldName) =>
      form.elements.namedItem(name) as HTMLInputElement;

    const isValid = (name: FieldName): boolean => {
      const el = field(name);
      if (name === "consent") return el.checked;
      const v = (el.value || "").trim();
      if (name === "name") return v.length >= 2;
      if (name === "email") return emailRe.test(v);
      if (name === "phone") return phoneRe.test(v) && v.replace(/\D/g, "").length >= 6;
      return true;
    };

    const showError = (name: FieldName, show: boolean) => {
      const el = field(name);
      const err = document.getElementById(`cta-${name}-error`);
      if (show) {
        el.setAttribute("aria-invalid", "true");
        if (err) err.textContent = messages[name];
      } else {
        el.removeAttribute("aria-invalid");
        if (err) err.textContent = "";
      }
    };

    const validateField = (name: FieldName): boolean => {
      const ok = isValid(name);
      showError(name, !ok);
      return ok;
    };

    // Validate text fields on blur; clear the error live once corrected.
    (["name", "phone", "email"] as FieldName[]).forEach((name) => {
      const el = field(name);
      el.addEventListener("blur", () => validateField(name));
      el.addEventListener("input", () => {
        if (el.getAttribute("aria-invalid")) validateField(name);
      });
    });
    field("consent").addEventListener("change", () => validateField("consent"));

    // ── CV upload ──────────────────────────────────────────────────────────
    // Upload the CV to Vercel Blob the moment it's selected (progress bar under
    // the button), so by submit time we only send its URL. Bypasses the ~4.5MB
    // serverless body limit. CV is optional — submitting without one is allowed.
    const cvInput = document.getElementById("cta-cv") as HTMLInputElement | null;
    const cvText = document.querySelector(".cta__file-text") as HTMLElement | null;
    const cvBar = document.querySelector(".cta__file-progress") as HTMLElement | null;
    const cvFill = document.querySelector(".cta__file-progress-fill") as HTMLElement | null;
    const cvStatusEl = document.querySelector(".cta__file-status") as HTMLElement | null;
    const cvDefault = cvText?.textContent || "";
    let cvUrl = "";
    let cvPending: Promise<unknown> | null = null;
    let cvEpoch = 0;

    const cvSetBar = (pct: number) => {
      if (cvBar) cvBar.hidden = false;
      if (cvFill) cvFill.style.width = `${Math.max(0, Math.min(100, pct))}%`;
    };
    const cvHideBar = () => {
      if (cvBar) cvBar.hidden = true;
      if (cvFill) cvFill.style.width = "0%";
    };
    const cvShow = (text: string, ok: boolean) => {
      if (!cvStatusEl) return;
      cvStatusEl.textContent = text;
      cvStatusEl.dataset.state = ok ? "ok" : "error";
      cvStatusEl.hidden = false;
    };

    cvInput?.addEventListener("change", () => {
      const file = cvInput.files && cvInput.files[0];
      if (cvText) cvText.textContent = file ? file.name : cvDefault;
      cvUrl = "";
      if (cvStatusEl) cvStatusEl.hidden = true;
      if (!file) {
        cvPending = null;
        cvHideBar();
        return;
      }
      const myEpoch = ++cvEpoch;
      cvSetBar(3);
      const safeName = (file.name || "cv").replace(/[^a-zA-Z0-9._-]+/g, "_").slice(-100);
      cvPending = upload(safeName, file, {
        access: "public",
        handleUploadUrl: withBase("/api/blob-upload"),
        contentType: file.type || undefined,
        onUploadProgress: (ev) => {
          if (cvEpoch === myEpoch) cvSetBar(ev.percentage);
        },
      })
        .then((blob) => {
          if (cvEpoch !== myEpoch) return;
          cvUrl = blob.url;
          cvHideBar();
          cvShow("✓ CV-то беше прикачено.", true);
        })
        .catch((err) => {
          if (cvEpoch !== myEpoch) return;
          cvHideBar();
          cvUrl = "";
          const m = (err instanceof Error && err.message) || "";
          cvShow(
            /size|large|maximum/i.test(m)
              ? "Файлът е твърде голям (макс. 15 MB)."
              : "Качването не бе успешно. Опитайте отново.",
            false,
          );
        });
    });

    const setStatus = (msg: string, state: "ok" | "error" | "") => {
      if (!status) return;
      status.textContent = msg;
      status.dataset.state = state;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      let firstInvalid: HTMLElement | null = null;
      for (const name of fields) {
        if (!validateField(name) && !firstInvalid) firstInvalid = field(name);
      }
      if (firstInvalid) {
        setStatus("", "");
        firstInvalid.focus();
        return;
      }

      // If a CV is attached, wait for its upload to finish before sending.
      if (cvInput?.files && cvInput.files[0]) {
        if (submit) submit.disabled = true;
        setStatus("Качване на CV…", "");
        try {
          await cvPending;
        } catch {
          /* handled below */
        }
        if (!cvUrl) {
          setStatus("CV файлът не се качи успешно. Изберете го отново или го премахнете.", "error");
          if (submit) submit.disabled = false;
          return;
        }
      }

      let tracking: Record<string, string> = {};
      try {
        tracking = JSON.parse(localStorage.getItem("inclusive_tracking") || "{}");
      } catch {
        /* ignore */
      }

      const data = {
        name: field("name").value.trim(),
        phone: field("phone").value.trim(),
        email: field("email").value.trim(),
        consent: field("consent").checked,
        ...(cvUrl ? { cv: cvUrl } : {}),
        ...tracking, // fbclid + utm_* for Facebook offline conversion tracking
      };

      if (submit) submit.disabled = true;
      setStatus("Изпращане…", "");

      try {
        const res = await fetch(withBase("/api/apply"), {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        const result = await res.json().catch(() => ({}));
        if (res.ok && result.ok) {
          form.reset();
          fields.forEach((n) => showError(n, false));
          setStatus("Пренасочване…", "ok");
          window.location.assign(withBase("/thank-you"));
          return;
        }
        setStatus(result.error || "Възникна грешка при изпращането. Моля, опитай отново.", "error");
      } catch {
        setStatus("Няма връзка със сървъра. Провери интернет връзката и опитай отново.", "error");
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>
