---
// Section: "За кого е" — who we're looking for.
// Each card has a description; on desktop only the accent card shows it (others reveal the
// same copy on mobile, matching the dedicated mobile design).
const cards = [
  {
    title: "Притежаваш характер и отговорност",
    text: "Знаеш, че университетът и дипломата не правят добрия брокер. Залагаш на почтеността и искаш да бъдеш истинското лице на доверието за своите клиенти.",
    mobileAccent: true,
  },
  {
    title: "Имаш търговски нюх и постоянство",
    text: "Имаш вътрешен устрем за продажби и си готов да действаш ден след ден, сделка след сделка, за да стигнеш целите, които си поставил.",
    accent: true,
  },
  {
    title: "Залагаш на самодисциплина и развитие",
    text: "Вярваш, че най-добрата инвестиция е в собствените ти умения, готов си да учиш постоянно и търсиш опора, за да движиш кариерата си напред.",
  },
  {
    title: "Вярваш в екипността и общите успехи",
    text: "Писнало ти е от вътрешна конкуренция и търсиш силен отбор, в който хората си споделят опит, пазят си гърба и растат заедно на пазара.",
  },
];
const [card1, card2, card3, card4] = cards;
---

<section class="ta" id="za-kogo-e">
  <div class="ta__inner container">
    <header class="ta__header">
      <h2 class="ta__title">Търсим хората, с които да вървим в една посока.</h2>
      <span class="gold-rule"></span>
      <p class="ta__subtitle">
        Опитът не е задължителен. Важното е да имаш хъс, а за обучението и подкрепата ще се
        погрижим ние. Ела в екипа ни, ако:
      </p>
    </header>

    <div class="ta__grid">
      <!-- Row 1 -->
      <div class="ta__media">
        <img src="/assets/images/target-1.jpg" alt="Екип на INclusive в офиса" width="399" height="301" loading="lazy" />
      </div>
      {[card1, card2].map((c) => (
        <article class={`ta__card${c.accent ? " ta__card--accent" : ""}${c.mobileAccent ? " ta__card--m-accent" : ""}`}>
          <span class="gold-rule"></span>
          <div class="ta__card-body">
            <h3 class="ta__card-title">{c.title}</h3>
            <p class="ta__card-text">{c.text}</p>
          </div>
        </article>
      ))}

      <!-- Row 2 -->
      {[card3, card4].map((c) => (
        <article class="ta__card">
          <span class="gold-rule"></span>
          <div class="ta__card-body">
            <h3 class="ta__card-title">{c.title}</h3>
            <p class="ta__card-text">{c.text}</p>
          </div>
        </article>
      ))}
      <div class="ta__media">
        <img src="/assets/images/target-2.jpg" alt="Среща на брокери от INclusive" width="399" height="303" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .ta {
    width: 100%;
    background-color: var(--color-gray-40);
    padding-block: 5em; /* 80px */
  }

  .ta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5em; /* 56px */
  }

  .ta__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75em; /* 12px */
    max-width: 39.625em; /* 634px */
    text-align: center;
  }

  .ta__title {
    font-family: var(--font-heading);
    font-size: 3em; /* 48px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    color: var(--color-gray-100);
  }

  .ta__subtitle {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-gray-80);
  }

  .ta__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5625em; /* 25px */
    width: 100%;
  }

  .ta__media {
    height: 18.8125em; /* 301px */
    border-radius: 0.25em;
    overflow: hidden;
  }

  .ta__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ta__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.5em;
    min-height: 18.8125em; /* 301px */
    padding: 1.75em 1.5em; /* 28px 24px */
    background-color: var(--color-gray-20);
  }

  .ta__card-body {
    display: flex;
    flex-direction: column;
    gap: 0.75em;
  }

  .ta__card-title {
    font-family: var(--font-heading);
    font-size: 1.75em; /* 28px */
    font-weight: 600;
    line-height: 1.3;
    text-transform: uppercase;
    color: var(--color-gray-100);
  }

  .ta__card--accent .ta__card-title {
    color: var(--color-gold-deep);
  }

  .ta__card-text {
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-gray-80);
  }

  /* Desktop: only the accent card shows its description */
  .ta__card:not(.ta__card--accent) .ta__card-text {
    display: none;
  }

  @media (max-width: 991px) {
    .ta__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .ta__grid {
      grid-template-columns: 1fr;
      gap: 1.5em;
    }

    .ta__card {
      min-height: auto;
    }

    /* Mobile design: every card shows its description, card 1 is the gold one */
    .ta__card-text {
      display: block;
    }

    .ta__card--accent .ta__card-title {
      color: var(--color-gray-100);
    }

    .ta__card--m-accent .ta__card-title {
      color: var(--color-gold-deep);
    }

    .ta__title {
      font-size: 1.875em; /* ~30px */
    }

    .ta__card-title {
      font-size: 1.375em; /* ~20px */
    }

    .ta__card-text,
    .ta__subtitle {
      font-size: 1.125em; /* ~18px */
    }
  }
</style>
