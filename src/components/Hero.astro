---
import { withBase } from "../lib/withBase";

const galleryImages = [
  "/assets/images/hero-1.jpg",
  "/assets/images/hero-2.jpg",
  "/assets/images/hero-3.jpg",
  "/assets/images/hero-4.jpg",
  "/assets/images/hero-5.jpg",
];
---

<section class="hero" id="top">
  <div class="hero__heading container">
    <h1 class="hero__title">
      <span class="hero__title-light">Стани част от </span><span class="hero__title-gold">печелившия отбор!</span>
    </h1>
    <p class="hero__subtitle">
      Чу кои са решенията и навиците зад най-бързо растящата имотна компания. Сега те каним да
      извървиш пътя от зрител до ключов играч в нашия екип.
    </p>
  </div>

  <div class="hero__gallery">
    {/* Images are duplicated (set + identical copy) so the marquee loops seamlessly. */}
    <ul class="hero__track">
      {[...galleryImages, ...galleryImages].map((src, i) => (
        <li class="hero__img" aria-hidden={i >= galleryImages.length ? "true" : undefined}>
          <img
            src={withBase(src)}
            alt={i < galleryImages.length ? `Екипът на INclusive — снимка ${i + 1}` : ""}
            width="384"
            height="256"
            loading={i < galleryImages.length ? "eager" : "lazy"}
            decoding="async"
          />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .hero {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4em; /* 64px */
    padding-top: 5em; /* 80px */
    overflow-x: clip;
  }

  .hero__heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75em; /* 12px */
    text-align: center;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: 3.5em; /* 56px */
    font-weight: 600;
    line-height: 1.2;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .hero__title-light {
    color: var(--color-gray-20);
  }

  .hero__title-gold {
    color: var(--color-gold);
  }

  .hero__subtitle {
    max-width: 40.25em; /* 644px */
    font-family: var(--font-body);
    font-size: 1.25em; /* 20px */
    font-weight: 300;
    line-height: 1.4;
    color: var(--color-gray-10);
  }

  /* Panoramic gallery — center largest, sides bleed off and fade to bg */
  .hero__gallery {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero__track {
    display: flex;
    align-items: center;
    width: max-content;
    will-change: transform;
  }

  .hero__img {
    flex-shrink: 0;
    width: 24em; /* 384px — uniform tiles so the marquee scrolls evenly */
    height: 16em; /* 256px */
    margin-right: 1.5em; /* 24px — per-item gap so the -50% marquee loop is seamless */
    border-radius: 0.75em; /* 12px */
    overflow: hidden;
  }

  .hero__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Edge fades to background */
  .hero__gallery::before,
  .hero__gallery::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 12.5em;
    z-index: 2;
    pointer-events: none;
  }

  .hero__gallery::before {
    left: 0;
    background: linear-gradient(90deg, var(--color-bg-dark) 0%, rgba(33, 35, 43, 0) 100%);
  }

  .hero__gallery::after {
    right: 0;
    background: linear-gradient(270deg, var(--color-bg-dark) 0%, rgba(33, 35, 43, 0) 100%);
  }

  @media (max-width: 991px) {
    .hero__title {
      white-space: normal;
      font-size: 2.75em; /* 44px */
    }
  }

  /* Mobile design: hero text is left-aligned, not centered */
  @media (max-width: 767px) {
    .hero__heading {
      align-items: flex-start;
      text-align: left;
    }

    .hero__title {
      font-size: 2.25em; /* ~36px */
    }

    /* No edge fades on mobile — images show fully */
    .hero__gallery::before,
    .hero__gallery::after {
      display: none;
    }
  }

  @media (max-width: 479px) {
    .hero__title {
      font-size: 2em; /* 32px */
    }
  }
</style>
