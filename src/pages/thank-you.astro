---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Благодарим — INclusive"
  description="Кандидатурата ти е приета. Линкът за достъп до уебинара е изпратен на имейла ти."
>
  <meta name="robots" content="noindex" slot="head" />

  <main class="ty" id="top">
    <div class="container ty__inner">
      <a href="/" class="ty__logo" aria-label="INclusive — начало">
        <img src="/assets/images/logo.png" alt="INclusive недвижими имоти" width="160" height="67" />
      </a>

      <span class="ty__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </span>

      <h1 class="ty__title">Благодарим ти!</h1>

      <p class="ty__lead">
        Мястото ти за уебинара е запазено. Изпратихме потвърждение и линк за достъп на посочения
        имейл — провери и папка „Спам“, ако не го откриеш.
      </p>

      <ul class="ty__details">
        <li class="ty__detail">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" />
          </svg>
          <span>Онлайн в Zoom</span>
        </li>
      </ul>

      <a class="btn ty__join" id="zoom-join" href="#" target="_blank" rel="noopener" hidden>
        Влез в уебинара
      </a>
      <a class="ty__back" href="/">Обратно към началото</a>
    </div>
  </main>
</BaseLayout>

<script>
  // Reveal the Zoom join button using the unique link the form stored on success.
  let url = "";
  try {
    url = sessionStorage.getItem("inclusive_join_url") || "";
  } catch {}
  if (url.startsWith("https://")) {
    const btn = document.getElementById("zoom-join") as HTMLAnchorElement | null;
    if (btn) {
      btn.href = url;
      btn.hidden = false;
    }
  }
</script>

<style>
  .ty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: var(--color-bg-dark);
    padding-block: 5em;
  }
  .ty__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5em;
    max-width: 38em;
  }
  .ty__logo {
    display: block;
    margin-bottom: 0.5em;
  }
  .ty__logo img {
    width: 10em; /* 160px */
    height: auto;
  }
  .ty__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.5em;
    height: 4.5em;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    color: var(--color-gold);
  }
  .ty__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 3em; /* 48px */
    line-height: 1.2;
    color: var(--color-gold);
    text-transform: uppercase;
  }
  .ty__lead {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.25em; /* 20px */
    line-height: 1.4;
    color: var(--color-text-primary);
  }
  .ty__details {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1em 2em;
    margin-block: 0.5em 1em;
  }
  .ty__detail {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.125em; /* 18px */
    color: var(--color-text-primary);
  }
  .ty__detail svg {
    color: var(--color-gold);
  }
  .ty__back {
    font-family: var(--font-body);
    font-size: 1em;
    color: var(--color-text-secondary);
    text-decoration: underline;
  }
  .ty__back:hover {
    color: var(--color-gold);
  }

  @media (max-width: 767px) {
    .ty__title {
      font-size: 2.25em;
    }
  }
</style>
