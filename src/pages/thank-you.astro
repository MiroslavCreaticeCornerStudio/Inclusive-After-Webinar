---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Благодарим — INclusive"
  description="Получихме кандидатурата ти. Ще се свържем с теб съвсем скоро."
>
  <meta name="robots" content="noindex" slot="head" />

  <main class="ty" id="top">
    <div class="container ty__inner">
      <a href="/" class="ty__logo" aria-label="INclusive — начало">
        <img src="/assets/images/logo.png" alt="INclusive недвижими имоти" width="160" height="67" />
      </a>

      <span class="ty__check" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 6 9 17l-5-5" />
        </svg>
      </span>

      <h1 class="ty__title">Благодарим ти!</h1>

      <p class="ty__lead">
        Получихме кандидатурата ти. Нашият екип ще се свърже с теб съвсем скоро със следващите
        стъпки — провери и папка „Спам“, в случай че имейлът ни попадне там.
      </p>

      <a class="ty__back" href="/">Обратно към началото</a>
    </div>
  </main>
</BaseLayout>

<style>
  .ty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    background-color: var(--color-bg-dark);
    padding-block: 5em;
  }
  .ty__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5em;
    max-width: 38em;
  }
  .ty__logo {
    display: block;
    margin-bottom: 0.5em;
  }
  .ty__logo img {
    width: 10em; /* 160px */
    height: auto;
  }
  .ty__check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.5em;
    height: 4.5em;
    border: 1px solid var(--color-gold);
    border-radius: 50%;
    color: var(--color-gold);
  }
  .ty__title {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 3em; /* 48px */
    line-height: 1.2;
    color: var(--color-gold);
    text-transform: uppercase;
  }
  .ty__lead {
    font-family: var(--font-body);
    font-weight: 300;
    font-size: 1.25em; /* 20px */
    line-height: 1.4;
    color: var(--color-text-primary);
  }
  .ty__back {
    font-family: var(--font-body);
    font-size: 1em;
    color: var(--color-text-secondary);
    text-decoration: underline;
    margin-top: 0.5em;
  }
  .ty__back:hover {
    color: var(--color-gold);
  }

  @media (max-width: 767px) {
    .ty__title {
      font-size: 2.25em;
    }
  }
</style>
