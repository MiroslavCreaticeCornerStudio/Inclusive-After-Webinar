---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title = "INclusive",
  description = "",
  lang = "bg",
  ogImage = "/assets/images/hero-3.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://inclusive.bg");
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://inclusive.bg");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#21232b" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="INclusive" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="bg_BG" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Brand fonts: Le Havre (display) + Futura PT (body) via Adobe Fonts (Typekit),
        same kit as the Webinar_Evelin project. Montserrat below is a Cyrillic-safe fallback. */}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/fas0rfi.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
    />

    {/* GSAP + Lenis — globals for the smooth-scroll + scroll-reveal init at the end of <body> */}
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
    <script is:inline src="https://unpkg.com/lenis@1.1.14/dist/lenis.min.js"></script>

    <slot name="head" />
  </head>
  <body>
    <a class="sr-only" href="#top">Към съдържанието</a>
    <slot />

    <!-- Facebook Ads offline-conversion tracking: capture fbclid + UTMs from the
         ad URL and persist them so they can be attached to the form submission. -->
    <script is:inline>
      (function () {
        try {
          var KEYS = [
            "fbclid",
            "utm_source",
            "utm_medium",
            "utm_campaign",
            "utm_term",
            "utm_content",
          ];
          var params = new URLSearchParams(window.location.search);
          var store = JSON.parse(localStorage.getItem("inclusive_tracking") || "{}");
          var changed = false;
          KEYS.forEach(function (k) {
            var v = params.get(k);
            if (v) {
              store[k] = v;
              changed = true;
            }
          });
          if (params.get("fbclid")) {
            store.fb_click_time = Math.floor(Date.now() / 1000);
            store.landing_url = window.location.href;
            changed = true;
          }
          if (changed) localStorage.setItem("inclusive_tracking", JSON.stringify(store));
        } catch (e) {
          /* localStorage unavailable — ignore */
        }
      })();
    </script>

    <!-- Light scroll-reveal animations (GSAP). Skipped entirely for reduced-motion;
         if GSAP fails to load, nothing is hidden and the page renders normally. -->
    <script is:inline>
      (function () {
        if (typeof gsap === "undefined" || typeof ScrollTrigger === "undefined") return;
        gsap.registerPlugin(ScrollTrigger);

        gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
          var ease = "power3.out"; // smooth, gentle deceleration

          // Lenis smooth (inertia) scrolling, driven by GSAP's ticker and synced to ScrollTrigger
          var lenis;
          var lenisRaf;
          if (typeof Lenis !== "undefined") {
            lenis = new Lenis({ duration: 1.1, smoothWheel: true });
            lenis.on("scroll", ScrollTrigger.update);
            lenisRaf = function (time) {
              lenis.raf(time * 1000);
            };
            gsap.ticker.add(lenisRaf);
            gsap.ticker.lagSmoothing(0);

            // Smooth in-page anchor navigation (clears the sticky navbar)
            var nav = document.querySelector(".navbar");
            var navOffset = nav ? -(nav.offsetHeight + 8) : 0;
            document.querySelectorAll('a[href^="#"]').forEach(function (a) {
              a.addEventListener("click", function (e) {
                var id = a.getAttribute("href");
                if (!id || id.length < 2) return;
                var target = document.querySelector(id);
                if (!target) return;
                e.preventDefault();
                lenis.scrollTo(target, { offset: navOffset });
              });
            });
          }

          // Hero intro on load
          gsap
            .timeline({ defaults: { ease: ease, duration: 1.05 } })
            .from(".hero__title", { y: 20, autoAlpha: 0, scale: 0.99 })
            .from(".hero__subtitle", { y: 18, autoAlpha: 0 }, "-=0.75")
            .from(".hero__gallery", { autoAlpha: 0, duration: 0.9 }, "-=0.6");

          // Hero gallery — seamless infinite marquee (images are duplicated in the markup,
          // so xPercent -50 advances exactly one set). Eases to a slow drift on hover.
          var heroTrack = document.querySelector(".hero__track");
          if (heroTrack) {
            var heroMarquee = gsap.to(heroTrack, {
              xPercent: -50,
              duration: 60,
              ease: "none",
              repeat: -1,
            });
            var heroGallery = document.querySelector(".hero__gallery");
            if (heroGallery) {
              heroGallery.addEventListener("mouseenter", function () {
                gsap.to(heroMarquee, { timeScale: 0.25, duration: 0.5, overwrite: true });
              });
              heroGallery.addEventListener("mouseleave", function () {
                gsap.to(heroMarquee, { timeScale: 1, duration: 0.5, overwrite: true });
              });
            }
          }

          // Section headings / intros — gently fade up as they enter (once)
          gsap.utils
            .toArray(
              ".ta__header, .expect__header, .everyday__head, .testimonials__header, .why__header, .cta__text, .footer__frame"
            )
            .forEach(function (el) {
              gsap.from(el, {
                y: 22,
                autoAlpha: 0,
                duration: 1.2,
                ease: ease,
                scrollTrigger: { trigger: el, start: "top 88%", once: true },
              });
            });

          // Grouped staggers — cards / list items ease in as the group enters
          [
            { trigger: ".ta__grid", targets: ":scope > *" },
            { trigger: ".expect__track", targets: ".expect__card" },
            { trigger: ".everyday__list", targets: ".everyday__item" },
            { trigger: ".testimonials__grid", targets: ".testimonial" },
            { trigger: ".why__content", targets: ".why-card, .why__media" },
          ].forEach(function (g) {
            var t = document.querySelector(g.trigger);
            if (!t) return;
            gsap.from(t.querySelectorAll(g.targets), {
              y: 22,
              autoAlpha: 0,
              scale: 0.985,
              duration: 1,
              ease: ease,
              stagger: { each: 0.11, ease: "power1.out" },
              scrollTrigger: { trigger: t, start: "top 88%", once: true },
            });
          });

          // Standalone content image
          gsap.utils.toArray(".everyday__media").forEach(function (el) {
            gsap.from(el, {
              autoAlpha: 0,
              y: 18,
              scale: 0.99,
              duration: 1.3,
              ease: ease,
              scrollTrigger: { trigger: el, start: "top 88%", once: true },
            });
          });

          // Recalculate trigger positions once fonts/images settle
          if (document.fonts && document.fonts.ready) {
            document.fonts.ready.then(function () {
              ScrollTrigger.refresh();
            });
          }
          window.addEventListener("load", function () {
            ScrollTrigger.refresh();
          });

          // Revert if the motion preference changes
          return function () {
            if (lenis) {
              gsap.ticker.remove(lenisRaf);
              lenis.destroy();
            }
          };
        });
      })();
    </script>
  </body>
</html>
