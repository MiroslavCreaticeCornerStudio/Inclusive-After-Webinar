---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  lang?: string;
  ogImage?: string;
}

const {
  title = "INclusive",
  description = "",
  lang = "bg",
  ogImage = "/assets/images/hero-3.jpg",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://inclusive.bg");
const ogImageUrl = new URL(ogImage, Astro.site ?? "https://inclusive.bg");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#21232b" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonical} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="INclusive" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="bg_BG" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />

    {/* Brand fonts: Le Havre (display) + Futura PT (body) via Adobe Fonts (Typekit),
        same kit as the Webinar_Evelin project. Montserrat below is a Cyrillic-safe fallback. */}
    <link rel="preconnect" href="https://use.typekit.net" crossorigin />
    <link rel="stylesheet" href="https://use.typekit.net/fas0rfi.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap"
    />

    <slot name="head" />
  </head>
  <body>
    <a class="sr-only" href="#top">Към съдържанието</a>
    <slot />

    <!-- Facebook Ads offline-conversion tracking: capture fbclid + UTMs from the
         ad URL and persist them so they can be attached to the form submission. -->
    <script is:inline>
      (function () {
        try {
          var KEYS = [
            "fbclid",
            "utm_source",
            "utm_medium",
            "utm_campaign",
            "utm_term",
            "utm_content",
          ];
          var params = new URLSearchParams(window.location.search);
          var store = JSON.parse(localStorage.getItem("inclusive_tracking") || "{}");
          var changed = false;
          KEYS.forEach(function (k) {
            var v = params.get(k);
            if (v) {
              store[k] = v;
              changed = true;
            }
          });
          if (params.get("fbclid")) {
            store.fb_click_time = Math.floor(Date.now() / 1000);
            store.landing_url = window.location.href;
            changed = true;
          }
          if (changed) localStorage.setItem("inclusive_tracking", JSON.stringify(store));
        } catch (e) {
          /* localStorage unavailable — ignore */
        }
      })();
    </script>
  </body>
</html>
