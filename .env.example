# Copy to `.env` and fill in real values. `.env` is gitignored.
# On Vercel/Netlify/etc., set these in the host's Environment Variables dashboard.

# Brevo (Sendinblue) transactional/marketing API
BREVO_API_KEY=
BREVO_LIST_ID=9

# Custom CRM (skyguru) — OPTIONAL. Leave unset to use the default endpoint
# (https://inclusive.skyguru.ai/api/v1/public/leads). The lead forward is best-effort
# and never blocks the Zoom/Brevo capture.
# CRM_ENDPOINT=
# SKYGURU_API_KEY=
