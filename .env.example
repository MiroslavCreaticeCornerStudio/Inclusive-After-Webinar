# Copy to `.env` and fill in real values. `.env` is gitignored.
# On Vercel/Netlify/etc., set these in the host's Environment Variables dashboard.

# Custom CRM (skyguru) — the only lead destination. Both vars are OPTIONAL:
# leave CRM_ENDPOINT unset to use the default endpoint
# (https://inclusive.skyguru.ai/api/v1/public/leads); set SKYGURU_API_KEY only
# if the endpoint requires bearer auth.
# CRM_ENDPOINT=
# SKYGURU_API_KEY=
